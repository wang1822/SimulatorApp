<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================
         GS215 模拟器配色方案（深色工业风）
         ======================================== -->

    <!-- 背景色 -->
    <SolidColorBrush x:Key="BackgroundBrush"       Color="#0F1117"/>  <!-- 窗口背景 -->
    <SolidColorBrush x:Key="SurfaceBrush"          Color="#1C2033"/>  <!-- 面板/卡片背景 -->
    <SolidColorBrush x:Key="SurfaceVariantBrush"   Color="#252B42"/>  <!-- 悬浮/次级面板 -->

    <!-- 主色调 -->
    <SolidColorBrush x:Key="PrimaryBrush"          Color="#2563EB"/>  <!-- 主按钮、Tab 激活 -->
    <SolidColorBrush x:Key="PrimaryHoverBrush"     Color="#1D4ED8"/>  <!-- 主按钮悬停 -->

    <!-- 状态色 -->
    <SolidColorBrush x:Key="SuccessBrush"          Color="#22C55E"/>  <!-- 运行中 -->
    <SolidColorBrush x:Key="WarningBrush"          Color="#F97316"/>  <!-- 轮询中/告警 -->
    <SolidColorBrush x:Key="ErrorBrush"            Color="#EF4444"/>  <!-- 故障/连接失败 -->
    <SolidColorBrush x:Key="InfoBrush"             Color="#3B82F6"/>  <!-- 信息 -->

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="#F1F5F9"/>  <!-- 主文字 -->
    <SolidColorBrush x:Key="TextSecondaryBrush"    Color="#94A3B8"/>  <!-- 辅助文字/标签 -->
    <SolidColorBrush x:Key="TextDisabledBrush"     Color="#475569"/>  <!-- 禁用文字 -->

    <!-- 边框/分割线 -->
    <SolidColorBrush x:Key="BorderBrush"           Color="#334155"/>
    <SolidColorBrush x:Key="DividerBrush"          Color="#1E293B"/>

    <!-- 输入框 -->
    <SolidColorBrush x:Key="InputBgBrush"          Color="#0F172A"/>
    <SolidColorBrush x:Key="InputBorderBrush"      Color="#334155"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#2563EB"/>

    <!-- 告警/故障行高亮 -->
    <SolidColorBrush x:Key="AlarmRowBrush"         Color="#2D1F00"/>
    <SolidColorBrush x:Key="FaultRowBrush"         Color="#2D0B0B"/>

    <!-- 颜色值（用于代码引用） -->
    <Color x:Key="PrimaryColor"   >#2563EB</Color>
    <Color x:Key="SuccessColor"   >#22C55E</Color>
    <Color x:Key="WarningColor"   >#F97316</Color>
    <Color x:Key="ErrorColor"     >#EF4444</Color>
    <Color x:Key="BackgroundColor">#0F1117</Color>

</ResourceDictionary>
