<Window x:Class="SimulatorApp.Slave.Views.NewProtocolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SimulatorApp.Shared.Converters"
        Title="新建协议配置"
        Width="720" Height="560" MinWidth="600" MinHeight="440"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 深色主题系统色覆盖 -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"        Color="#1E293B"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#2563EB"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding"    Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3F55"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标签 -->
        <Style x:Key="DlgLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <!-- 输入框 -->
        <Style x:Key="DlgTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#1E293B"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- ComboBox -->
        <Style x:Key="DlgCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1E293B"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid TextElement.Foreground="{TemplateBinding Foreground}">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter x:Name="ContentSite"
                                    IsHitTestVisible="False"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                    Margin="8,0,24,0" VerticalAlignment="Center"/>
                            <ToggleButton Focusable="False"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                RelativeSource={RelativeSource TemplatedParent}}"
                                    ClickMode="Press" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="Transparent"/>
                                            <Path Grid.Column="1" HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0 0 L 4 4 L 8 0 Z" Fill="#94A3B8"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background"  Value="#253347"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Background"  Value="#172033"/>
                                <Setter Property="Foreground"                           Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 主按钮 -->
        <Style x:Key="DlgPrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,4"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <!-- 次按钮 -->
        <Style x:Key="DlgSecBtn" TargetType="Button">
            <Setter Property="Background"      Value="#334155"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- 标题栏 -->
            <RowDefinition Height="Auto"/> <!-- 配置区 -->
            <RowDefinition Height="*"/>    <!-- 预览表格 -->
            <RowDefinition Height="52"/>   <!-- 底部按钮 -->
        </Grid.RowDefinitions>

        <!-- ── 标题栏 ── -->
        <Border Grid.Row="0" Background="#1C2033"
                BorderBrush="#334155" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="新建协议配置" Foreground="#E2E8F0"
                           FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="  —  配置监听端点并导入寄存器协议"
                           Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── 配置区 ── -->
        <Border Grid.Row="1" Background="#131929" Padding="16,12"
                BorderBrush="#1E293B" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- 第一行：设备名 + 协议类型 + Slave ID -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,4" VerticalAlignment="Center">
                        <TextBlock Text="设备名称：" Style="{StaticResource DlgLabel}"/>
                        <TextBox Width="160" Style="{StaticResource DlgTextBox}"
                                 Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,4" VerticalAlignment="Center">
                        <TextBlock Text="协议类型：" Style="{StaticResource DlgLabel}"/>
                        <ComboBox Width="80" Style="{StaticResource DlgCombo}"
                                  SelectedIndex="{Binding ProtocolIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="TCP"/>
                            <ComboBoxItem Content="RTU"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,4" VerticalAlignment="Center">
                        <TextBlock Text="Slave ID：" Style="{StaticResource DlgLabel}"/>
                        <TextBox Width="50" Style="{StaticResource DlgTextBox}"
                                 Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </WrapPanel>

                <!-- 第二行：TCP / RTU 参数 -->
                <WrapPanel Orientation="Horizontal">
                    <!-- TCP 参数 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center"
                                Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="监听地址：" Style="{StaticResource DlgLabel}"/>
                        <TextBox Width="120" Style="{StaticResource DlgTextBox}"
                                 Text="{Binding ListenAddress, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center"
                                Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="端口：" Style="{StaticResource DlgLabel}"/>
                        <TextBox Width="65" Style="{StaticResource DlgTextBox}"
                                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!-- RTU 参数 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center"
                                Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="串口：" Style="{StaticResource DlgLabel}"/>
                        <ComboBox Width="90" Style="{StaticResource DlgCombo}"
                                  ItemsSource="{Binding AvailableComPorts}"
                                  SelectedItem="{Binding ComPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextSearchEnabled="True"/>
                        <Button Content="↺" Style="{StaticResource DlgSecBtn}"
                                Command="{Binding RefreshComPortsCommand}"
                                Width="26" Padding="0" Margin="4,0,0,0" ToolTip="刷新串口列表"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center"
                                Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="波特率：" Style="{StaticResource DlgLabel}"/>
                        <ComboBox Width="90" Style="{StaticResource DlgCombo}"
                                  ItemsSource="{Binding BaudRateOptions}"
                                  SelectedItem="{Binding BaudRate, Mode=TwoWay}"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ── 预览表格区 ── -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 工具栏：导入按钮 + 行数提示 -->
            <Border Grid.Row="0" Background="#1C2033"
                    BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                <DockPanel Margin="12,0" VerticalAlignment="Center">
                    <Button Content="📑 粘贴协议" Style="{StaticResource DlgSecBtn}"
                            Command="{Binding PasteProtocolCommand}"
                            Margin="0,0,6,0" DockPanel.Dock="Left"
                            ToolTip="从 Excel 复制协议行后点此导入"/>
                    <Button Content="📂 导入协议 Excel" Style="{StaticResource DlgSecBtn}"
                            Command="{Binding ImportExcelCommand}"
                            Margin="0,0,12,0" DockPanel.Dock="Left"
                            ToolTip="打开协议文档 Excel 文件导入寄存器列表"/>
                    <TextBlock Text="{Binding RowCountText}"
                               Foreground="#64748B" FontSize="11"
                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                </DockPanel>
            </Border>

            <!-- 预览 DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionUnit="Cell"
                      Background="#0D1526"
                      Foreground="#CBD5E1"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#131929"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1E293B"
                      RowHeight="24"
                      FontFamily="Consolas"
                      FontSize="11">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#1C2033"/>
                        <Setter Property="Foreground"      Value="#64748B"/>
                        <Setter Property="Padding"         Value="8,3"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="BorderBrush"     Value="#334155"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground"      Value="#CBD5E1"/>
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="6,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2563EB33"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Resources>
                    <Style x:Key="ColText" TargetType="TextBlock">
                        <Setter Property="Foreground"         Value="#CBD5E1"/>
                        <Setter Property="VerticalAlignment"  Value="Center"/>
                        <Setter Property="Padding"            Value="6,2"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="地址"   Binding="{Binding Address}"     Width="65"  ElementStyle="{StaticResource ColText}"/>
                    <DataGridTextColumn Header="中文名" Binding="{Binding ChineseName}"  Width="*"   MinWidth="80" ElementStyle="{StaticResource ColText}"/>
                    <DataGridTextColumn Header="英文名" Binding="{Binding EnglishName}"  Width="*"   MinWidth="80" ElementStyle="{StaticResource ColText}"/>
                    <DataGridTextColumn Header="读写"   Binding="{Binding ReadWrite}"    Width="50"  ElementStyle="{StaticResource ColText}"/>
                    <DataGridTextColumn Header="范围"   Binding="{Binding Range}"        Width="100" ElementStyle="{StaticResource ColText}"/>
                    <DataGridTextColumn Header="单位"   Binding="{Binding Unit}"         Width="55"  ElementStyle="{StaticResource ColText}"/>
                    <DataGridTextColumn Header="描述"   Binding="{Binding Note}"         Width="2*"  MinWidth="100" ElementStyle="{StaticResource ColText}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 空状态提示 -->
            <TextBlock Grid.Row="1" Text="请点击「粘贴协议」或「导入协议 Excel」载入寄存器数据"
                       Foreground="#334155" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Rows.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- ── 底部按钮 ── -->
        <Border Grid.Row="3" Background="#1C2033"
                BorderBrush="#334155" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="16,0">
                <Button Content="取消" Style="{StaticResource DlgSecBtn}"
                        Command="{Binding CancelCommand}" Width="80" Margin="0,0,8,0"/>
                <Button Content="✔ 确定" Style="{StaticResource DlgPrimaryBtn}"
                        Command="{Binding ConfirmCommand}" Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
