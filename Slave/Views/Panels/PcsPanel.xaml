<UserControl x:Class="SimulatorApp.Slave.Views.Panels.PcsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:ctrl="clr-namespace:SimulatorApp.Slave.Views.Controls"
             Background="{StaticResource SurfaceBrush}">
    <!--
        PCS 储能变流器面板
        DataContext = PcsViewModel（由 SlavePanel 通过绑定传入）
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8">

            <!-- ===== 遥测数值区域 ===== -->
            <TextBlock Text="【遥测数值】" Style="{StaticResource SectionTitleStyle}"/>
            <Separator Style="{StaticResource DividerStyle}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <!-- 行：标签 | 输入框 | 单位 -->
                <!-- 直流 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="直流电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding DcVoltage, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="直流电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding DcCurrent, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="A"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="直流功率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding DcPower, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="kW" Style="{StaticResource LabelStyle}"/>

                <!-- 逆变电压 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="逆变A相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding PcsPhaseAVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="逆变B相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding PcsPhaseBVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="逆变C相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding PcsPhaseCVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="温度1" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding PcsTemp1, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="℃"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="温度2" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="7" Grid.Column="1" Text="{Binding PcsTemp2, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="7" Grid.Column="2" Text="℃"  Style="{StaticResource LabelStyle}"/>

                <!-- 中间列：电网电压 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="电网A相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="5" Text="{Binding GridPhaseAVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="6" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="电网B相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="5" Text="{Binding GridPhaseBVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="6" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="4" Text="电网C相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="5" Text="{Binding GridPhaseCVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="6" Text="V"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="4" Text="电网A相电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="5" Text="{Binding GridPhaseACurrent, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="6" Text="A"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="4" Text="电网B相电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="5" Text="{Binding GridPhaseBCurrent, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="6" Text="A"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="4" Text="电网C相电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="5" Text="{Binding GridPhaseCCurrent, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="5" Grid.Column="6" Text="A"  Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="4" Text="电网频率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="6" Grid.Column="5" Text="{Binding GridFrequency, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="6" Grid.Column="6" Text="Hz" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="7" Grid.Column="4" Text="电网功率因数" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="7" Grid.Column="5" Text="{Binding GridPowerFactor, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="7" Grid.Column="6" Text="—"  Style="{StaticResource LabelStyle}"/>

                <!-- 右列：功率/电量 -->
                <TextBlock Grid.Row="0" Grid.Column="8" Text="逆变器总有功" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="9" Text="{Binding PcsTotalActPower, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="10" Text="kW" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="8" Text="逆变A相有功" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="9" Text="{Binding PcsPhaseAActPower, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="10" Text="kW" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="8" Text="逆变总无功" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="9" Text="{Binding PcsTotalReactPower, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="10" Text="kvar" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="8" Text="日充电量" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="9" Text="{Binding DailyChargedEnergy, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="10" Text="kWh" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="8" Text="日放电量" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="9" Text="{Binding DailyDischargedEnergy, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="10" Text="kWh" Style="{StaticResource LabelStyle}"/>
            </Grid>

            <!-- ===== 运行状态 ===== -->
            <TextBlock Text="【运行状态】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="充放电状态：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="100" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding ChargingStateItems}"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding ChargingState, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="运行状态：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="100" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding OperatingStateItems}"
                              DisplayMemberPath="Display"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding OperatingState, Mode=TwoWay}"/>
                </StackPanel>
            </WrapPanel>

            <!-- ===== 故障/告警注入 ===== -->
            <TextBlock Text="【故障/告警注入】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>

            <TextBlock Text="告警字1（偏移+224）：" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
            <ctrl:AlarmCheckList DataContext="{Binding Alarm1Items}"/>

            <TextBlock Text="告警字2（偏移+225）：" Style="{StaticResource LabelStyle}" Margin="0,6,0,2"/>
            <ctrl:AlarmCheckList DataContext="{Binding Alarm2Items}"/>

            <TextBlock Text="故障字1（偏移+228）：" Style="{StaticResource LabelStyle}" Margin="0,6,0,2"
                       Foreground="{StaticResource ErrorBrush}"/>
            <ctrl:AlarmCheckList DataContext="{Binding Fault1Items}"/>

            <TextBlock Text="故障字2（偏移+229）：" Style="{StaticResource LabelStyle}" Margin="0,6,0,2"
                       Foreground="{StaticResource ErrorBrush}"/>
            <ctrl:AlarmCheckList DataContext="{Binding Fault2Items}"/>

            <!-- 操作按钮 -->
            <WrapPanel Orientation="Horizontal" Margin="0,12,0,4">
                <Button Content="🎲 一键生成数据"
                        Command="{Binding GenerateDataCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="🗑 清除所有告警"
                        Command="{Binding ClearAlarmsCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
