<UserControl x:Class="SimulatorApp.Slave.Views.Panels.MpptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:SimulatorApp.Slave.Views.Controls"
             Background="{StaticResource SurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8">
            <TextBlock Text="【遥测数值】" Style="{StaticResource SectionTitleStyle}"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/> <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/> <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/> <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="输出电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding OutputVolt, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="输出电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding OutputCurrent, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="A" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="PV总功率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding PVTotalPower, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="W" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="PV1直流电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding DCVolt1, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="PV1直流电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding DCCurrent1, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="A" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="散热片温度" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding HeatSinkTemp, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="℃" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="当日PV发电量" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding DailyPVGenTotal, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="kWh" Style="{StaticResource LabelStyle}"/>

                <!-- 右列 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="PV2直流电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="5" Text="{Binding DCVolt2, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="6" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="PV2直流电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="5" Text="{Binding DCCurrent2, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="6" Text="A" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="4" Text="PV1直流功率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="5" Text="{Binding DCPower1, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="6" Text="W" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="4" Text="PV2直流功率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="5" Text="{Binding DCPower2, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="6" Text="W" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="4" Text="历史PV发电量" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="5" Text="{Binding HistoryPvGenCapacity, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="6" Text="kWh" Style="{StaticResource LabelStyle}"/>
            </Grid>

            <TextBlock Text="【运行状态】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="运行模式：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="100" Style="{StaticResource DataComboBoxStyle}"
                          ItemsSource="{Binding MpptModeItems}" DisplayMemberPath="Display"
                          SelectedValuePath="Value" SelectedValue="{Binding MpptOperatingMode, Mode=TwoWay}"/>
            </StackPanel>

            <TextBlock Text="【故障/告警注入】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <TextBlock Text="告警字：" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
            <ctrl:AlarmCheckList DataContext="{Binding AlarmItems}"/>
            <TextBlock Text="故障字：" Style="{StaticResource LabelStyle}" Margin="0,6,0,2" Foreground="{StaticResource ErrorBrush}"/>
            <ctrl:AlarmCheckList DataContext="{Binding FaultItems}"/>

            <WrapPanel Orientation="Horizontal" Margin="0,12,0,4">
                <Button Content="🎲 一键生成数据" Command="{Binding GenerateDataCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="🗑 清除所有告警" Command="{Binding ClearAlarmsCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
