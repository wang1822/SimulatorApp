<UserControl x:Class="SimulatorApp.Slave.Views.Panels.StsInstrumentPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:SimulatorApp.Slave.Views.Controls"
             Background="{StaticResource SurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8">
            <TextBlock Text="【遥测数值】" Style="{StaticResource SectionTitleStyle}"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="160"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="55"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/> <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/> <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/> <RowDefinition Height="34"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="主路A相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding MainPhaseVoltA, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="主路B相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding MainPhaseVoltB, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="主路C相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding MainPhaseVoltC, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="主路频率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding MainFrequency, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Hz" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="备路A相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding BackupPhaseVoltA, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="备路B相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding BackupPhaseVoltB, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="备路C相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding BackupPhaseVoltC, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="V" Style="{StaticResource LabelStyle}"/>

                <!-- 右列 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="备路频率" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="5" Text="{Binding BackupFrequency, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="6" Text="Hz" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="负载A相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="1" Grid.Column="5" Text="{Binding LoadPhaseVoltA, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="6" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="2" Grid.Column="4" Text="负载B相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="5" Text="{Binding LoadPhaseVoltB, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="6" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="3" Grid.Column="4" Text="负载C相电压" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="3" Grid.Column="5" Text="{Binding LoadPhaseVoltC, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="3" Grid.Column="6" Text="V" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="4" Grid.Column="4" Text="负载A相电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="4" Grid.Column="5" Text="{Binding LoadCurrentA, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="4" Grid.Column="6" Text="A" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="5" Grid.Column="4" Text="负载B相电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="5" Grid.Column="5" Text="{Binding LoadCurrentB, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="5" Grid.Column="6" Text="A" Style="{StaticResource LabelStyle}"/>

                <TextBlock Grid.Row="6" Grid.Column="4" Text="负载C相电流" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="6" Grid.Column="5" Text="{Binding LoadCurrentC, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Style="{StaticResource DataTextBoxStyle}"/>
                <TextBlock Grid.Row="6" Grid.Column="6" Text="A" Style="{StaticResource LabelStyle}"/>
            </Grid>

            <TextBlock Text="【运行状态】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="STS运行模式：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="130" Style="{StaticResource DataComboBoxStyle}"
                          ItemsSource="{Binding StsOperatingModeItems}" DisplayMemberPath="Display"
                          SelectedValuePath="Value" SelectedValue="{Binding StsOperatingMode, Mode=TwoWay}"/>
            </StackPanel>

            <TextBlock Text="【故障/告警注入】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <TextBlock Text="告警字：" Style="{StaticResource LabelStyle}" Margin="0,4,0,2"/>
            <ctrl:AlarmCheckList DataContext="{Binding AlarmItems}"/>
            <TextBlock Text="故障字：" Style="{StaticResource LabelStyle}" Margin="0,6,0,2" Foreground="{StaticResource ErrorBrush}"/>
            <ctrl:AlarmCheckList DataContext="{Binding FaultItems}"/>

            <WrapPanel Orientation="Horizontal" Margin="0,12,0,4">
                <Button Content="🎲 一键生成数据" Command="{Binding GenerateDataCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="🗑 清除所有告警" Command="{Binding ClearAlarmsCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
