<UserControl x:Class="SimulatorApp.Slave.Views.Panels.ImportedDevicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SimulatorApp.Shared.Converters"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.Resources>
            <conv:BoolToColorConverter x:Key="BoolToColor"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 工具栏 -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="12,6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="＋ 新增行"
                        Height="24" Padding="10,0"
                        Background="#2563EB" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12"
                        Click="AddRow_Click"/>
                <Button x:Name="EditProtocolButton" DockPanel.Dock="Right" Content="编辑协议"
                        Height="24" Padding="10,0" Margin="0,0,4,0"
                        Background="#0F766E" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12"
                        Click="EditProtocol_Click"
                        ToolTip="跳转到寄存器检视编辑该协议，保存后替换原协议"/>
                <!-- 搜索框 + 按钮 -->
                <Button DockPanel.Dock="Right" Content="搜索"
                        Height="24" Padding="10,0" Margin="0,0,4,0"
                        Background="#334155" Foreground="#E2E8F0"
                        BorderThickness="0" Cursor="Hand" FontSize="12"
                        Command="{Binding SearchCommand}"
                        ToolTip="按中英文名过滤（Enter 同效）"/>
                <Button DockPanel.Dock="Right" Content="×"
                        Height="24" Width="24" Padding="0" Margin="0,0,2,0"
                        Background="Transparent" Foreground="#64748B"
                        BorderThickness="0" Cursor="Hand" FontSize="14"
                        Command="{Binding ClearSearchCommand}"
                        ToolTip="清除搜索"/>
                <TextBox DockPanel.Dock="Right"
                         x:Name="SearchBox"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="150" Height="24" Margin="0,0,0,0"
                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                         BorderBrush="#334155" BorderThickness="1"
                         Padding="6,0" FontSize="12" VerticalContentAlignment="Center"
                         ToolTip="输入关键词，匹配中文名或英文名，按 Enter 或「搜索」按钮筛选"
                         KeyDown="SearchBox_KeyDown"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DeviceName}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="API:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBox Text="{Binding ApiUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="150" Height="24" Margin="0,0,6,0"
                             Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                             BorderBrush="#334155" BorderThickness="1"
                             Padding="6,0" FontSize="12" VerticalContentAlignment="Center"
                             ToolTip="填写 API 地址，返回 JSON 数值字段后按英文名/中文名比对当前值"/>
                    <TextBlock Text="Token:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBox Text="{Binding ApiAuthorization, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="90" Height="24" Margin="0,0,6,0"
                             Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                             BorderBrush="#334155" BorderThickness="1"
                             Padding="6,0" FontSize="12" VerticalContentAlignment="Center"
                             ToolTip="Token / Authorization 请求头"/>
                    <TextBlock Text="误差:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <TextBox Text="{Binding VerifyToleranceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="42" Height="24" Margin="0,0,6,0"
                             Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                             BorderBrush="#334155" BorderThickness="1"
                             Padding="4,0" FontFamily="Consolas" FontSize="12"
                             VerticalContentAlignment="Center" ToolTip="允许误差"/>
                    <Button Content="立即比对"
                            Height="24" MinWidth="68" Padding="8,0" Margin="0,0,6,0"
                            Background="#16A34A" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="12"
                            Command="{Binding VerifyOnceCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 随机生成工具栏 -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="0,4,8,4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 随机生成按钮 -->
                <Button DockPanel.Dock="Right" Content="⚄ 随机生成"
                        Height="24" Padding="10,0"
                        Background="#7C3AED" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="12"
                        Command="{Binding GenerateRandomCommand}"
                        ToolTip="对勾选行生成 [最小值, 最大值] 范围内的随机整数"/>
                <!-- 最大值 -->
                <TextBox DockPanel.Dock="Right"
                         Text="{Binding MaxValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="70" Height="24" Margin="0,0,6,0"
                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                         BorderBrush="#334155" BorderThickness="1"
                         Padding="6,0" FontFamily="Consolas" FontSize="12"
                         VerticalContentAlignment="Center"
                         ToolTip="最大值 (0–65535)"/>
                <TextBlock DockPanel.Dock="Right" Text="最大值:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <!-- 最小值 -->
                <TextBox DockPanel.Dock="Right"
                         Text="{Binding MinValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="70" Height="24" Margin="0,0,0,0"
                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                         BorderBrush="#334155" BorderThickness="1"
                         Padding="6,0" FontFamily="Consolas" FontSize="12"
                         VerticalContentAlignment="Center"
                         ToolTip="最小值 (0–65535)"/>
                <TextBlock DockPanel.Dock="Right" Text="最小值:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <!-- 全选复选框：贴近随机生成范围，便于先选行再生成 -->
                <CheckBox DockPanel.Dock="Right"
                          x:Name="SelectAllCheckBox"
                          IsThreeState="False"
                          Loaded="SelectAllCheckBox_Loaded"
                          Click="SelectAllCheckBox_Click"
                          Content="全选" Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="12" VerticalAlignment="Center"
                          Margin="0,0,12,0"/>
                <Button Content="定位未通过"
                        Height="24" Padding="10,0" Margin="0"
                        Background="#334155" Foreground="#E2E8F0"
                        BorderThickness="0" Cursor="Hand" FontSize="12"
                        Click="NextUnverified_Click"
                        ToolTip="跳转到下一条未通过（灰点）记录"/>
                <TextBlock Text="{Binding VerifyStatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding VerifyStatusText}"/>
            </DockPanel>
        </Border>


        <!-- 寄存器表格：风格与主站 DataGrid 保持一致 -->
        <DataGrid Grid.Row="2" x:Name="RegisterDataGrid"
                  ItemsSource="{Binding FilteredRows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  BeginningEdit="RegisterDataGrid_BeginningEdit_DoubleClickOnly"
                  PreparingCellForEdit="RegisterDataGrid_PreparingCellForEdit_CaretToEnd"
                  MouseDoubleClick="RegisterDataGrid_MouseDoubleClick"
                  SelectionUnit="CellOrRowHeader"
                  CanUserResizeRows="True"
                  Background="{StaticResource BackgroundBrush}"
                  RowBackground="Transparent"
                  AlternatingRowBackground="#0D1526"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  SelectionMode="Extended"
                  RowHeight="28"
                  ClipboardCopyMode="ExcludeHeader"
                  FontFamily="Consolas"
                  FontSize="12">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="复制" Click="RegisterDataGrid_CopyMenuItem_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <!-- 覆盖 WPF 默认亮蓝系统选中色，防止文字被高亮背景遮挡 -->
            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                Color="#1A2744"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"            Color="#E2E8F0"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#0F172A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#94A3B8"/>
            </DataGrid.Resources>

            <!-- 行悬停 Tooltip -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Tag" Value="{Binding}"/>
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Background="#1E293B" BorderBrush="#334155" BorderThickness="1"
                                     DataContext="{Binding PlacementTarget.Tag,
                                                  RelativeSource={RelativeSource Self}}">
                                <StackPanel MaxWidth="520" Margin="6,4">
                                    <TextBlock FontWeight="Bold" FontSize="12" Foreground="#E2E8F0"
                                               TextWrapping="Wrap">
                                        <Run Text="{Binding ChineseName, Mode=OneWay}"/>
                                        <Run Foreground="#64748B" Text="  /  "/>
                                        <Run Foreground="#94A3B8" Text="{Binding EnglishName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0">
                                        <Run Text="地址："/><Run Text="{Binding Address, Mode=OneWay}"/>
                                        <Run Text="   单位："/><Run Text="{Binding Unit, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"
                                               TextWrapping="Wrap" MaxWidth="500">
                                        <Run Text="范围："/><Run Text="{Binding Range, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Note, Mode=OneWay}" TextWrapping="Wrap"
                                               Foreground="#CBD5E1" FontSize="11"
                                               Margin="0,6,0,0" MaxWidth="500"/>
                                </StackPanel>
                            </ToolTip>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1A2744"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsPending}" Value="True">
                            <Setter Property="Background" Value="#1A0D09"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
                    <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="Padding"         Value="8,4"/>
                    <Setter Property="FontSize"        Value="12"/>
                    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Background"      Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="8,2"/>
                    <!-- 自定义模板：移除 WPF 默认 VSM，Triggers 完全接管背景 -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2563EB22"/>
                        </Trigger>
                        <Trigger Property="IsEditing" Value="True">
                            <Setter Property="Background"      Value="#1E293B"/>
                            <Setter Property="BorderBrush"     Value="#2563EB"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Padding"         Value="0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <!-- API 比对绿点：灰色=未通过，绿色=通过；点击可手动切换并实时入库 -->
                <DataGridTemplateColumn Header="验" Width="42" CanUserSort="False" IsReadOnly="True"
                                        ClipboardContentBinding="{Binding IsVerified}">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Width="28" Height="24"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FocusVisualStyle="{x:Null}"
                                    Cursor="Hand"
                                    ToolTip="点击手动标记/取消 API 比对通过"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.ToggleVerifyRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Background="Transparent">
                                            <Ellipse x:Name="VerifyDot"
                                                     Width="12" Height="12"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Stroke="#94A3B8"
                                                     StrokeThickness="1"
                                                     Fill="#475569"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsVerified}" Value="True">
                                                <Setter TargetName="VerifyDot" Property="Fill" Value="#22C55E"/>
                                                <Setter TargetName="VerifyDot" Property="Stroke" Value="#86EFAC"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="VerifyDot" Property="StrokeThickness" Value="2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 勾选列（随机生成） -->
                <DataGridTemplateColumn Header="" Width="32" CanUserSort="False" IsReadOnly="True"
                                        ClipboardContentBinding="{Binding IsChecked}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 地址（十进制） -->
                <DataGridTemplateColumn Header="地址 *" Width="70"
                                        ClipboardContentBinding="{Binding Address}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Address, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding AddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                         BorderBrush="#EF4444" BorderThickness="1"
                                         Padding="4,0" FontFamily="Consolas" FontSize="12"
                                         VerticalContentAlignment="Center"
                                         ToolTip="十进制或 0x 十六进制，范围 0–65535"
                                         LostFocus="PendingRow_LostFocus"
                                         Loaded="PendingAddressBox_Loaded">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 中文名（可内联编辑，LostFocus 触发 DB 持久化） -->
                <DataGridTemplateColumn Header="中文名 *" Width="*" MinWidth="100"
                                        ClipboardContentBinding="{Binding ChineseName}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding ChineseName, Mode=OneWay}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="8,2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Text="{Binding ChineseName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                         BorderBrush="#EF4444" BorderThickness="1"
                                         Padding="4,0" FontSize="12"
                                         VerticalContentAlignment="Center"
                                         LostFocus="PendingRow_LostFocus">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ChineseName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Background="#1E293B" Foreground="#E2E8F0" CaretBrush="#E2E8F0"
                                     BorderBrush="#2563EB" BorderThickness="1"
                                     Padding="6,2" FontSize="12" VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- 英文名（可内联编辑，LostFocus 触发 DB 持久化） -->
                <DataGridTextColumn Header="英文名" Binding="{Binding EnglishName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="*" MinWidth="80"/>

                <!-- 当前值：实时显示 RegisterBank 值，双击可写入，右键切换十进制/二进制 -->
                <DataGridTemplateColumn Header="当前值" Width="130" MinWidth="100"
                                        ClipboardContentBinding="{Binding CurrentValueDisplay}">
                    <!-- 正常显示：蓝色加粗，右键切换显示模式 -->
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CurrentValueDisplay, Mode=OneWay}"
                                       FontWeight="Bold"
                                       Foreground="#60A5FA"
                                       FontSize="15"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"
                                       ToolTip="双击编辑写入；右键切换显示模式">
                                <TextBlock.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                             RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="十进制"
                                                  IsChecked="{Binding IsDecimalMode, Mode=OneWay}"
                                                  Command="{Binding SetDisplayModeCommand}"
                                                  CommandParameter="dec"/>
                                        <MenuItem Header="二进制"
                                                  IsChecked="{Binding IsBinaryMode, Mode=OneWay}"
                                                  Command="{Binding SetDisplayModeCommand}"
                                                  CommandParameter="bin"/>
                                        <MenuItem Header="十六进制"
                                                  IsChecked="{Binding IsHexMode, Mode=OneWay}"
                                                  Command="{Binding SetDisplayModeCommand}"
                                                  CommandParameter="hex"/>
                                        <Separator/>
                                        <MenuItem Header="复制" Click="CurrentValue_CopyMenuItem_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <!-- 编辑模式：TextBox 输入新值，失焦写入 -->
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding WriteValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E293B"
                                     Foreground="#E2E8F0"
                                     CaretBrush="#E2E8F0"
                                     SelectionBrush="#2563EB"
                                     BorderBrush="#2563EB"
                                     BorderThickness="1"
                                     Padding="6,2"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     FontWeight="Bold"
                                     VerticalContentAlignment="Center"
                                     ToolTip="输入新值后失焦写入寄存器（十进制、二进制或十六进制，与右键模式一致）"
                                     Loaded="WriteCell_Loaded"
                                     GotFocus="WriteCell_GotFocus"
                                     LostFocus="WriteCell_LostFocus"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- 单位（只读属性：编辑框失焦时由代码写回） -->
                <DataGridTemplateColumn Header="单位" Width="55" MinWidth="55"
                                        ClipboardContentBinding="{Binding Unit}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Unit, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Tag="Unit"
                                     Text="{Binding Unit, Mode=OneWay}"
                                     Background="#1E293B"
                                     Foreground="#E2E8F0"
                                     CaretBrush="#E2E8F0"
                                     BorderBrush="#2563EB"
                                     BorderThickness="1"
                                     Padding="6,2"
                                     FontFamily="Consolas, Courier New"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     Loaded="ReadOnlyMetaEdit_Loaded"
                                     LostFocus="ReadOnlyMetaEdit_LostFocus"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- 范围列：可编辑，显示折行 -->
                <DataGridTemplateColumn Header="范围" Width="120" MinWidth="80"
                                        ClipboardContentBinding="{Binding Range}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Range}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.ToolTip>
                                    <ToolTip Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                                        <TextBlock Text="{Binding Range}"
                                                   MaxWidth="500" TextWrapping="Wrap"
                                                   Foreground="#E2E8F0" FontSize="12"/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Tag="Range"
                                     Text="{Binding Range, Mode=OneWay}"
                                     Background="#1E293B"
                                     Foreground="#E2E8F0"
                                     CaretBrush="#E2E8F0"
                                     BorderBrush="#2563EB"
                                     BorderThickness="1"
                                     Padding="6,2"
                                     FontFamily="Consolas, Courier New"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     Loaded="ReadOnlyMetaEdit_Loaded"
                                     LostFocus="ReadOnlyMetaEdit_LostFocus"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- 描述列：可编辑，显示折行 -->
                <DataGridTemplateColumn Header="描述" Width="2*" MinWidth="120"
                                        ClipboardContentBinding="{Binding Note}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Note}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       FontFamily="Consolas, Courier New"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.ToolTip>
                                    <ToolTip Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                                        <TextBlock Text="{Binding Note}"
                                                   MaxWidth="500" TextWrapping="Wrap"
                                                   Foreground="#E2E8F0" FontSize="12"/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Tag="Note"
                                     Text="{Binding Note, Mode=OneWay}"
                                     Background="#1E293B"
                                     Foreground="#E2E8F0"
                                     CaretBrush="#E2E8F0"
                                     BorderBrush="#2563EB"
                                     BorderThickness="1"
                                     Padding="6,2"
                                     FontFamily="Consolas, Courier New"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     Loaded="ReadOnlyMetaEdit_Loaded"
                                     LostFocus="ReadOnlyMetaEdit_LostFocus"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <!-- 删除行 -->
                <DataGridTemplateColumn Header="" Width="56" IsReadOnly="True" CanUserResize="False">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="×" Width="28" Height="22"
                                    Background="Transparent" Foreground="#EF4444"
                                    BorderThickness="0" FontSize="14" FontWeight="Bold"
                                    Cursor="Hand" Tag="{Binding}"
                                    HorizontalAlignment="Center"
                                    Click="DeleteRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
