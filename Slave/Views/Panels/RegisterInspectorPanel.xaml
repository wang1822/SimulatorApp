<UserControl x:Class="SimulatorApp.Slave.Views.Panels.RegisterInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SimulatorApp.Slave.ViewModels"
             Background="{StaticResource SurfaceBrush}">
    <!--
        寄存器检视器面板
        DataContext = RegisterInspectorViewModel
        功能：手动输入地址，实时读写 RegisterBank，类似 Modbus Slave 数据表
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部工具栏 ===== -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>

                <!-- 第一行：批量加载 -->
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="批量加载：起始地址" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="70" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding BatchStart, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="起始寄存器地址（十进制）"/>
                    <TextBlock Text="  数量" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="8,0,6,0"/>
                    <TextBox Width="55" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding BatchCount, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="加载寄存器数量（最多 256）"/>
                    <Button Content="📥 批量加载" Command="{Binding LoadBatchCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="8,0,0,0" ToolTip="加载指定范围的寄存器地址到表格"/>
                </WrapPanel>

                <!-- 第二行：添加单行 + 全局操作 -->
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="添加单地址：" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="70" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="寄存器地址（十进制，0~65535）">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddRowCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="＋ 添加" Command="{Binding AddRowCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,0"/>
                    <Button Content="↻ 刷新全部" Command="{Binding RefreshAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="12,0,0,0"
                            ToolTip="从 RegisterBank 重新读取所有行的当前值"/>
                    <Button Content="💾 保存为协议设备"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0"
                            ToolTip="填写设备信息并保存到协议导入设备"
                            Click="SaveInspectorAsProtocol_Click"/>
                    <Button Content="🗑 清空" Command="{Binding ClearRowsCommand}"
                            Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0"/>
                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- 协议保存区域：撑满剩余空间 -->
        <Border Grid.Row="1" Margin="12,8,12,12" Padding="8"
                Background="#111827"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="协议设备保存信息（* 必填）"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

                <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="设备名称 *" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox x:Name="InlineDeviceNameBox" Width="160" MinHeight="28"
                                 Style="{StaticResource DataTextBoxStyle}"/>
                    </StackPanel>
                    <TextBlock Text="协议类型 / Slave ID / 监听地址 / 端口：自动使用上方默认监听配置"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,4"/>
                </WrapPanel>

                <DataGrid Grid.Row="2"
                          x:Name="InlineProtocolDraftGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Loaded="InlineProtocolDraftGrid_Loaded"
                          PreviewKeyDown="InlineProtocolDraftGrid_PreviewKeyDown"
                          ItemsSource="{Binding ProtocolDraftRows, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="{StaticResource BackgroundBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#0D1526"
                          BorderThickness="0"
                          MinRowHeight="30"
                          FontSize="12"
                          SelectionMode="Extended"
                          SelectionUnit="CellOrRowHeader"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style x:Key="InlineCellTextStyle" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="2,0"/>
                        </Style>
                        <Style x:Key="InlineCellEditTextBoxStyle" TargetType="TextBox">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="2,0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="CaretBrush" Value="#60A5FA"/>
                            <Setter Property="SelectionBrush" Value="#1D4ED8"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <EventSetter Event="GotKeyboardFocus" Handler="EditableCellTextBox_GotKeyboardFocus"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="EditableCellTextBox_PreviewMouseLeftButtonDown"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="6,2"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDown"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#172A4A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="地址*" Binding="{Binding Address}" Width="90" IsReadOnly="True"
                                            ElementStyle="{StaticResource InlineCellTextStyle}"/>
                        <DataGridTemplateColumn Header="中文名*" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ChineseName}"
                                               Style="{StaticResource InlineCellTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Text="{Binding ChineseName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InlineCellEditTextBoxStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="英文名" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding EnglishName}"
                                               Style="{StaticResource InlineCellTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Text="{Binding EnglishName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InlineCellEditTextBoxStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="当前值" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             BorderBrush="Transparent"
                                             Padding="2,0"
                                             Margin="0"
                                             IsReadOnly="True"
                                             IsHitTestVisible="False"
                                             Focusable="False"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             CaretBrush="#60A5FA"
                                             SelectionBrush="#1D4ED8"
                                             FocusVisualStyle="{x:Null}"
                                             VerticalContentAlignment="Center"
                                             Loaded="CurrentValueTextBox_Loaded"
                                             Unloaded="CurrentValueTextBox_Unloaded"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             BorderBrush="Transparent"
                                             Padding="2,0"
                                             Margin="0"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             CaretBrush="#60A5FA"
                                             SelectionBrush="#1D4ED8"
                                             FocusVisualStyle="{x:Null}"
                                             VerticalContentAlignment="Center"
                                             GotKeyboardFocus="EditableCellTextBox_GotKeyboardFocus"
                                             PreviewMouseLeftButtonDown="EditableCellTextBox_PreviewMouseLeftButtonDown"
                                             TextChanged="CurrentValueTextBox_TextChanged"
                                             Loaded="CurrentValueTextBox_Loaded"
                                             GotFocus="CurrentValueTextBox_GotFocus"
                                             LostFocus="CurrentValueTextBox_LostFocus"
                                             Unloaded="CurrentValueTextBox_Unloaded"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="范围" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Range}"
                                               Style="{StaticResource InlineCellTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Text="{Binding Range, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InlineCellEditTextBoxStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="单位" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Unit}"
                                               Style="{StaticResource InlineCellTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InlineCellEditTextBoxStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="描述" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Note}"
                                               Style="{StaticResource InlineCellTextStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox MinHeight="24"
                                             Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InlineCellEditTextBoxStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="3">
                    <TextBlock x:Name="InlineWriteStatusTextBlock"
                               Foreground="#86EFAC"
                               FontSize="11"/>
                    <TextBlock
                           x:Name="InlineSaveErrorTextBlock"
                           Foreground="#FCA5A5"
                           FontSize="11"
                           Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
