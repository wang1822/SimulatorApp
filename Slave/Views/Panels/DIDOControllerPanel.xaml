<UserControl x:Class="SimulatorApp.Slave.Views.Panels.DIDOControllerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,8">
            <TextBlock Text="【DI 开关量输入（12路）】" Style="{StaticResource SectionTitleStyle}"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI1：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di1, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI2：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di2, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI3：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di3, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI4：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di4, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI5：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di5, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI6：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di6, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI7：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di7, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI8：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di8, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI9：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di9, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI10：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di10, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI11：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di11, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DI12：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DiStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Di12, Mode=TwoWay}"/>
                </StackPanel>
            </WrapPanel>

            <TextBlock Text="【DO 开关量输出（6路）】" Style="{StaticResource SectionTitleStyle}" Margin="0,12,0,4"/>
            <Separator Style="{StaticResource DividerStyle}"/>
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DO1：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
