                              SelectedValuePath="Value" SelectedValue="{Binding Do2, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DO3：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DoStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Do3, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DO4：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DoStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Do4, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                    <TextBlock Text="DO5：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DoStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Do5, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                    <TextBlock Text="DO6：" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="40"/>
                    <ComboBox Width="75" Style="{StaticResource DataComboBoxStyle}"
                              ItemsSource="{Binding DoStateItems}" DisplayMemberPath="Display"
                              SelectedValuePath="Value" SelectedValue="{Binding Do6, Mode=TwoWay}"/>
                </StackPanel>
            </WrapPanel>

            <WrapPanel Orientation="Horizontal" Margin="0,12,0,4">
                <Button Content="🎲 一键生成数据" Command="{Binding GenerateDataCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
