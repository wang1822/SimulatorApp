<Window x:Class="SimulatorApp.Slave.Views.AddRegisterRowDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增寄存器行"
        Width="400" Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#94A3B8"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TB" TargetType="TextBox">
            <Setter Property="Background"             Value="#1E293B"/>
            <Setter Property="Foreground"             Value="#E2E8F0"/>
            <Setter Property="BorderBrush"            Value="#334155"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Padding"                Value="6,3"/>
            <Setter Property="Height"                 Value="28"/>
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"             Value="#E2E8F0"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="新增寄存器行"
                   Foreground="#E2E8F0" FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- 字段表格 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 地址（必填） -->
            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}">
                地址 *
            </TextBlock>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="AddressBox" Style="{StaticResource TB}"
                       ToolTip="十进制或 0x 十六进制，范围 0–65535"
                       KeyDown="Dialog_KeyDown"/>

            <!-- 中文名 -->
            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Lbl}" Text="中文名"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="ChineseNameBox" Style="{StaticResource TB}"
                       KeyDown="Dialog_KeyDown"/>

            <!-- 英文名 -->
            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource Lbl}" Text="英文名"/>
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="EnglishNameBox" Style="{StaticResource TB}"
                       KeyDown="Dialog_KeyDown"/>

            <!-- 读写 -->
            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource Lbl}" Text="读写"/>
            <TextBox   Grid.Row="6" Grid.Column="1" x:Name="ReadWriteBox" Style="{StaticResource TB}"
                       Text="R/W" KeyDown="Dialog_KeyDown"/>

            <!-- 范围 -->
            <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource Lbl}" Text="范围"/>
            <TextBox   Grid.Row="8" Grid.Column="1" x:Name="RangeBox" Style="{StaticResource TB}"
                       KeyDown="Dialog_KeyDown"/>

            <!-- 单位 -->
            <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource Lbl}" Text="单位"/>
            <TextBox   Grid.Row="10" Grid.Column="1" x:Name="UnitBox" Style="{StaticResource TB}"
                       KeyDown="Dialog_KeyDown"/>

            <!-- 备注 -->
            <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource Lbl}" Text="备注"/>
            <TextBox   Grid.Row="12" Grid.Column="1" x:Name="NoteBox" Style="{StaticResource TB}"
                       KeyDown="Dialog_KeyDown"/>

            <!-- 错误提示 -->
            <TextBlock Grid.Row="14" Grid.ColumnSpan="2" x:Name="ErrorText"
                       Foreground="#EF4444" FontSize="11" Visibility="Collapsed"
                       TextWrapping="Wrap"/>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="72" Height="30" Margin="0,0,8,0"
                    Background="#1E293B" Foreground="#94A3B8"
                    BorderBrush="#334155" BorderThickness="1"
                    Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="确认新增" Width="88" Height="30"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
