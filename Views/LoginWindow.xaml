<Window x:Class="SimulatorApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录"
        Width="440"
        MinWidth="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Border Margin="24"
            Padding="24"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <StackPanel>
            <TextBlock Text="EMS 设备故障模拟器"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="20"
                       FontWeight="SemiBold"/>
            <TextBlock Text="请输入账号和密码"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="0,6,0,22"/>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="用户名" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="UserNameBox"
                         Height="36"
                         Style="{StaticResource DataTextBoxStyle}"
                         FontSize="14"
                         Text="admin"
                         KeyDown="Input_KeyDown"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="密码" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="36"
                             Background="#1E293B"
                             Foreground="#E2E8F0"
                             CaretBrush="#E2E8F0"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Padding="10,0"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             KeyDown="Input_KeyDown"/>
            </StackPanel>

            <TextBlock x:Name="ErrorText"
                       Foreground="#EF4444"
                       FontSize="12"
                       MinHeight="18"
                       Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="退出"
                        Width="78" MinHeight="36"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="登录"
                        Width="88" MinHeight="36"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="16,0"
                        FontSize="13"
                        Cursor="Hand"
                        Click="Login_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
