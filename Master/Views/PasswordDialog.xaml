<Window x:Class="SimulatorApp.Master.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="验证身份" Width="320"
        SizeToContent="Height" MinHeight="160"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A"
        Foreground="#E2E8F0">

    <StackPanel Margin="24,20,24,16">
        <TextBlock x:Name="MessageText" Text="请输入操作密码："
                   Foreground="#94A3B8" FontSize="13" Margin="0,0,0,10"/>

        <PasswordBox x:Name="PasswordBox"
                     Height="32" Padding="8,4"
                     Background="#1E293B" Foreground="#E2E8F0"
                     BorderBrush="#334155" BorderThickness="1"
                     CaretBrush="#E2E8F0"
                     FontFamily="Consolas" FontSize="14"
                     KeyDown="PasswordBox_KeyDown"/>

        <TextBlock x:Name="ErrorText" Text="密码错误，请重试"
                   Foreground="#EF4444" FontSize="11" Margin="0,6,0,0"
                   Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="72" Height="30"
                    Background="#334155" Foreground="#E2E8F0"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="确认" Width="72" Height="30"
                    Background="#2563EB" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Confirm_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
