<Window x:Class="SimulatorApp.Master.Views.SaveStationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SimulatorApp.Shared.Converters"
        Title="保存站点配置"
        Width="1040" Height="680" MinWidth="800" MinHeight="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 覆盖 ComboBox 弹出层及高亮系统色，使其符合深色主题 -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"          Color="#1E293B"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"      Color="#E2E8F0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"       Color="#2563EB"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"   Color="#FFFFFF"/>
        <!-- ComboBoxItem 深色悬停 / 选中样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Padding"    Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3F55"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 对话框标签样式 -->
        <Style x:Key="DlgLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <!-- 对话框输入框 -->
        <Style x:Key="DlgTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#1E293B"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- 对话框 ComboBox（完整 ControlTemplate，彻底替换 Aero 默认渲染）-->
        <Style x:Key="DlgCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1E293B"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <!-- TextElement.Foreground 让子 TextBlock 继承正确颜色 -->
                        <Grid TextElement.Foreground="{TemplateBinding Foreground}">
                            <!-- 整体背景边框 -->
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <!-- 选中项文字（不参与命中测试，点击穿透到 ToggleButton）-->
                            <ContentPresenter x:Name="ContentSite"
                                    IsHitTestVisible="False"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                    Margin="8,0,24,0"
                                    VerticalAlignment="Center"/>
                            <!-- 透明 ToggleButton 覆盖整控件，右侧仅绘制箭头 -->
                            <ToggleButton Focusable="False"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                RelativeSource={RelativeSource TemplatedParent}}"
                                    ClickMode="Press"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="22"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="Transparent"/>
                                            <Path Grid.Column="1"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="#94A3B8"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- 下拉弹出层 -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#1E293B"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background"  Value="#253347"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Background"  Value="#172033"/>
                                <Setter Property="Foreground"                           Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 主按钮 -->
        <Style x:Key="DlgPrimaryBtn" TargetType="Button">
            <Setter Property="Background"  Value="#2563EB"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"    Value="16,4"/>
            <Setter Property="Height"     Value="32"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
        <!-- 次按钮 -->
        <Style x:Key="DlgSecBtn" TargetType="Button">
            <Setter Property="Background"  Value="#334155"/>
            <Setter Property="Foreground"  Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"    Value="12,4"/>
            <Setter Property="Height"     Value="28"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- DataGrid 公共样式 -->
        <Style x:Key="DlgDg" TargetType="DataGrid">
            <Setter Property="Background"            Value="#0F172A"/>
            <Setter Property="RowBackground"         Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#1E293B"/>
            <Setter Property="Foreground"            Value="#E2E8F0"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="CanUserAddRows"        Value="True"/>
            <Setter Property="CanUserDeleteRows"     Value="True"/>
            <Setter Property="RowHeight"             Value="26"/>
            <Setter Property="FontSize"              Value="12"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding"    Value="6,3"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"       Value="#E2E8F0"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="4,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 站点信息 -->
            <RowDefinition Height="*"/>     <!-- Tab 内容 -->
            <RowDefinition Height="Auto"/>  <!-- 底部按钮 -->
        </Grid.RowDefinitions>

        <!-- ===== 顶部：站点信息 ===== -->
        <Border Grid.Row="0" Background="#1E293B" Padding="16,10"
                BorderBrush="#334155" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal">
                <!-- 站点名称 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                    <TextBlock Text="站点名称*：" Style="{StaticResource DlgLabel}"/>
                    <TextBox Width="130" Style="{StaticResource DlgTextBox}"
                             Text="{Binding StationName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <!-- 协议 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                    <TextBlock Text="协议：" Style="{StaticResource DlgLabel}"/>
                    <ComboBox Width="80" Style="{StaticResource DlgCombo}"
                              SelectedIndex="{Binding Protocol, Mode=TwoWay}">
                        <ComboBoxItem Content="TCP"/>
                        <ComboBoxItem Content="RTU"/>
                    </ComboBox>
                </StackPanel>
                <!-- TCP 参数 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                            Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="IP：" Style="{StaticResource DlgLabel}"/>
                    <TextBox Width="120" Style="{StaticResource DlgTextBox}"
                             Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                            Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="端口：" Style="{StaticResource DlgLabel}"/>
                    <TextBox Width="65" Style="{StaticResource DlgTextBox}"
                             Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <!-- RTU 参数 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                            Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="串口：" Style="{StaticResource DlgLabel}"/>
                    <ComboBox Width="90" Style="{StaticResource DlgCombo}"
                              ItemsSource="{Binding AvailableComPorts}"
                              SelectedItem="{Binding PortName, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center"
                            Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="波特率：" Style="{StaticResource DlgLabel}"/>
                    <ComboBox Width="90" Style="{StaticResource DlgCombo}"
                              ItemsSource="{Binding BaudRateOptions}"
                              SelectedItem="{Binding BaudRate, Mode=TwoWay}"/>
                </StackPanel>
                <!-- 公共 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,4" VerticalAlignment="Center">
                    <TextBlock Text="Slave ID：" Style="{StaticResource DlgLabel}"/>
                    <TextBox Width="50" Style="{StaticResource DlgTextBox}"
                             Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                    <TextBlock Text="轮询间隔(ms)：" Style="{StaticResource DlgLabel}"/>
                    <TextBox Width="70" Style="{StaticResource DlgTextBox}"
                             Text="{Binding PollIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ===== 中间：Tab（遥测/遥控）===== -->
        <TabControl Grid.Row="1" Background="#0F172A"
                    BorderBrush="#334155" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background"  Value="#1E293B"/>
                    <Setter Property="Foreground"  Value="#94A3B8"/>
                    <Setter Property="Padding"     Value="16,6"/>
                    <Setter Property="FontSize"    Value="13"/>
                </Style>
            </TabControl.Resources>

            <!-- ── 遥测 Tab ── -->
            <TabItem Header="遥测（只读，功能码 0x03）">
                <DockPanel>
                    <!-- 工具栏 -->
                    <ToolBarTray DockPanel.Dock="Top" Background="#1E293B">
                        <ToolBar Background="#1E293B" Band="0">
                            <Button Content="＋ 新增行"
                                    Command="{Binding AddTelemeterRowCommand}"
                                    Style="{StaticResource DlgSecBtn}" Margin="0,0,4,0"/>
                            <Button Content="－ 删除所选行"
                                    Command="{Binding RemoveTelemeterRowCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=TmGrid}"
                                    Style="{StaticResource DlgSecBtn}" Margin="0,0,4,0"/>
                            <Separator Background="#334155"/>
                            <Button Content="📂 导入 Excel"
                                    Command="{Binding ImportTelemeterExcelCommand}"
                                    Style="{StaticResource DlgSecBtn}" Margin="0,0,4,0"/>
                            <Button Content="📋 粘贴(TSV)"
                                    Command="{Binding PasteTelemeterCommand}"
                                    Style="{StaticResource DlgSecBtn}"/>
                            <TextBlock Text="  格式：起始地址|数量|变量名|中文名|读写|单位|数据类型|寄存器类型|比例系数|偏移量|取值范围|说明"
                                       Foreground="#475569" FontSize="11" VerticalAlignment="Center" Margin="8,0"/>
                        </ToolBar>
                    </ToolBarTray>

                    <DataGrid x:Name="TmGrid" Style="{StaticResource DlgDg}"
                              ItemsSource="{Binding TelemeterRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="起始地址"   Binding="{Binding StartAddress}"     Width="70"/>
                            <DataGridTextColumn Header="数量"       Binding="{Binding Quantity}"         Width="50"/>
                            <DataGridTextColumn Header="变量名"     Binding="{Binding VariableName}"     Width="110"/>
                            <DataGridTextColumn Header="中文名"     Binding="{Binding ChineseName}"      Width="130"/>
                            <DataGridTextColumn Header="读写"       Binding="{Binding ReadWrite}"        Width="50"/>
                            <DataGridTextColumn Header="单位"       Binding="{Binding Unit}"             Width="60"/>
                            <DataGridTextColumn Header="数据类型"   Binding="{Binding DataType}"         Width="80"/>
                            <DataGridTextColumn Header="寄存器类型" Binding="{Binding RegisterDataType}" Width="80"/>
                            <DataGridTextColumn Header="比例系数"   Binding="{Binding ScaleFactor}"      Width="70"/>
                            <DataGridTextColumn Header="偏移量"     Binding="{Binding Offset}"           Width="60"/>
                            <DataGridTextColumn Header="取值范围"   Binding="{Binding ValueRange}"       Width="160"/>
                            <DataGridTextColumn Header="说明"       Binding="{Binding Description}"      Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── 遥控 Tab ── -->
            <TabItem Header="遥控（可写，功能码 0x06）">
                <DockPanel>
                    <ToolBarTray DockPanel.Dock="Top" Background="#1E293B">
                        <ToolBar Background="#1E293B" Band="0">
                            <Button Content="＋ 新增行"
                                    Command="{Binding AddControlRowCommand}"
                                    Style="{StaticResource DlgSecBtn}" Margin="0,0,4,0"/>
                            <Button Content="－ 删除所选行"
                                    Command="{Binding RemoveControlRowCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=CtGrid}"
                                    Style="{StaticResource DlgSecBtn}" Margin="0,0,4,0"/>
                            <Separator Background="#334155"/>
                            <Button Content="📂 导入 Excel"
                                    Command="{Binding ImportControlExcelCommand}"
                                    Style="{StaticResource DlgSecBtn}" Margin="0,0,4,0"/>
                            <Button Content="📋 粘贴(TSV)"
                                    Command="{Binding PasteControlCommand}"
                                    Style="{StaticResource DlgSecBtn}"/>
                        </ToolBar>
                    </ToolBarTray>

                    <DataGrid x:Name="CtGrid" Style="{StaticResource DlgDg}"
                              ItemsSource="{Binding ControlRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="起始地址"   Binding="{Binding StartAddress}"     Width="70"/>
                            <DataGridTextColumn Header="数量"       Binding="{Binding Quantity}"         Width="50"/>
                            <DataGridTextColumn Header="变量名"     Binding="{Binding VariableName}"     Width="110"/>
                            <DataGridTextColumn Header="中文名"     Binding="{Binding ChineseName}"      Width="130"/>
                            <DataGridTextColumn Header="读写"       Binding="{Binding ReadWrite}"        Width="50"/>
                            <DataGridTextColumn Header="单位"       Binding="{Binding Unit}"             Width="60"/>
                            <DataGridTextColumn Header="数据类型"   Binding="{Binding DataType}"         Width="80"/>
                            <DataGridTextColumn Header="寄存器类型" Binding="{Binding RegisterDataType}" Width="80"/>
                            <DataGridTextColumn Header="比例系数"   Binding="{Binding ScaleFactor}"      Width="70"/>
                            <DataGridTextColumn Header="偏移量"     Binding="{Binding Offset}"           Width="60"/>
                            <DataGridTextColumn Header="取值范围"   Binding="{Binding ValueRange}"       Width="160"/>
                            <DataGridTextColumn Header="说明"       Binding="{Binding Description}"      Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- ===== 底部按钮 ===== -->
        <Border Grid.Row="2" Background="#1E293B" Padding="16,10"
                BorderBrush="#334155" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="✓ 保存配置"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource DlgPrimaryBtn}"
                            Width="110" Margin="0,0,8,0"/>
                    <Button Content="取消"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource DlgSecBtn}"
                            Width="70"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
