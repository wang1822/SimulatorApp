<UserControl x:Class="SimulatorApp.Master.Views.MasterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SimulatorApp.Shared.Converters"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToColorConverter     x:Key="BoolToColor"/>
        <conv:BoolToStringConverter    x:Key="BoolToString"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 顶部连接栏 -->
            <RowDefinition Height="*"/>     <!-- 左站点列表 + 右数据区 -->
            <RowDefinition Height="180"/>   <!-- 日志 -->
        </Grid.RowDefinitions>

        <!-- ===== 顶部：Modbus 连接配置 ===== -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- 第一行：连接参数 -->
                <WrapPanel Orientation="Horizontal">
                    <!-- 协议 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" VerticalAlignment="Center">
                        <TextBlock Text="协议：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <ComboBox Width="80" Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding ProtocolItems}" DisplayMemberPath="Display"
                                  SelectedValuePath="Value" SelectedValue="{Binding Protocol, Mode=TwoWay}"/>
                    </StackPanel>
                    <!-- TCP：IP（可编辑下拉，列出本机 IP）-->
                    <StackPanel Orientation="Horizontal" Margin="0,0,4,4" VerticalAlignment="Center"
                                Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="目标IP：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <ComboBox Width="140" IsEditable="True"
                                  Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding AvailableHosts}"
                                  Text="{Binding RemoteHost, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="↻" Width="26" Height="26" Margin="4,0,0,0"
                                Command="{Binding RefreshAvailableHostsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="14"
                                ToolTip="刷新本机 IP 列表"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" VerticalAlignment="Center"
                                Visibility="{Binding IsTcpMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="端口：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <TextBox Width="65" Style="{StaticResource DataTextBoxStyle}"
                                 Text="{Binding RemotePort, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!-- RTU：串口 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" VerticalAlignment="Center"
                                Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="串口：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <ComboBox Width="90" Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding AvailableComPorts}"
                                  SelectedItem="{Binding ComPort, Mode=TwoWay}"/>
                        <Button Content="↻" Width="26" Height="26" Margin="4,0,0,0"
                                Command="{Binding RefreshComPortsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="0" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" VerticalAlignment="Center"
                                Visibility="{Binding IsRtuMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="波特率：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <ComboBox Width="90" Style="{StaticResource DataComboBoxStyle}"
                                  ItemsSource="{Binding BaudRateOptions}"
                                  SelectedItem="{Binding BaudRate, Mode=TwoWay}"/>
                    </StackPanel>
                    <!-- Slave ID + 轮询间隔 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" VerticalAlignment="Center">
                        <TextBlock Text="Slave ID：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <TextBox Width="50" Style="{StaticResource DataTextBoxStyle}"
                                 Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" VerticalAlignment="Center">
                        <TextBlock Text="间隔(ms)：" Style="{StaticResource LabelStyle}" Margin="0,0,4,0"/>
                        <TextBox Width="65" Style="{StaticResource DataTextBoxStyle}"
                                 Text="{Binding PollIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!-- 连接按钮 -->
                    <Button Content="{Binding IsConnected, Converter={StaticResource BoolToString},
                                     ConverterParameter='⏹ 断开连接|▶ 开始轮询'}"
                            Command="{Binding ToggleMasterCommand}"
                            Width="110" Height="32"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,10,4"/>
                    <!-- 状态指示 -->
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToColor},
                                    ConverterParameter='#22C55E|#475569'}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" FontSize="12" Margin="0,0,14,0"/>
                    <TextBlock VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="已轮询 "/><Run Text="{Binding PollCount}"/><Run Text=" 次"/>
                    </TextBlock>
                </WrapPanel>

                <!-- 第二行：操作按钮 -->
                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="💾 新建配置" Command="{Binding NewStationCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="🗑 删除所选站点" Command="{Binding DeleteStationCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="🔴 清除绿点" Command="{Binding ClearVerifiedCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="📊 导出数据" Command="{Binding ExportPollDataCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="🗑 删除日志文件" Command="{Binding ClearLogCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </WrapPanel>

                <!-- 第三行：API 比对配置 -->
                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="API 地址：" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Width="280" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="API 接口地址，如 http://172.168.3.100:8080/lcmain?type=homePageInfo"
                             Margin="0,0,10,4"/>
                    <TextBlock Text="Authorization：" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Width="200" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding ApiAuthorization, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Bearer Token 等鉴权头内容" Margin="0,0,6,4"/>
                    <TextBlock Text="未通过：" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,2,4"/>
                    <TextBlock Foreground="#EF4444" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,4">
                        <Run Text="{Binding VerifyFailCount}"/><Run Text=" 项"/>
                    </TextBlock>
                    <TextBlock Text="误差≤" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,4,4"/>
                    <TextBox Width="55" Style="{StaticResource DataTextBoxStyle}"
                             Text="{Binding VerifyTolerance, UpdateSourceTrigger=LostFocus}"
                             Margin="0,0,10,4"/>
                    <Button Content="立即比对" Command="{Binding VerifyOnceCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,4"/>
                    <TextBlock Text="{Binding VerifyStatusText}"
                               Foreground="#22C55E" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,0,4"/>
                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- ===== 中间：左站点列表 + 右数据区 ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="160"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：DB 连接 + 站点列表 -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="8">

                    <!-- DB 连接区 -->
                    <StackPanel DockPanel.Dock="Top">
                        <DockPanel Margin="0,4,0,4">
                            <Button DockPanel.Dock="Right"
                                    Content="刷新DB"
                                    Command="{Binding ConnectDbCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="26" FontSize="11" Padding="8,0"/>
                            <Ellipse DockPanel.Dock="Left" Width="8" Height="8" VerticalAlignment="Center"
                                     Margin="0,0,6,0"
                                     Fill="{Binding IsDbConnected, Converter={StaticResource BoolToColor},
                                            ConverterParameter='#22C55E|#475569'}"/>
                            <TextBlock Text="{Binding DbStatusText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </DockPanel>
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,4,0,4"/>
                    </StackPanel>

                    <!-- 站点列表标题 + 站点名称编辑框 -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <TextBlock Text="已保存站点"
                                   Style="{StaticResource SectionTitleStyle}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    
                    <!-- 修改站点名称 -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding SelectedStationEditName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             Style="{StaticResource DataTextBoxStyle}"
                             ToolTip="编辑后失焦自动保存站点名称"
                             Margin="0,0,0,4"
                             Visibility="{Binding HasSelectedStation, Converter={StaticResource BoolToVis}}"/>

                    <!-- 站点列表 -->
                    <ListBox ItemsSource="{Binding Stations}"
                             SelectedItem="{Binding SelectedStation, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="13">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding Name}" Padding="2,2"/>
                                    <!-- IsTemporary=true 表示内存临时站点，显示橙色"临时"标签 -->
                                    <Border Visibility="{Binding IsTemporary,
                                                Converter={StaticResource BoolToVis}}"
                                            Background="#78350F" CornerRadius="3"
                                            Padding="4,1" Margin="4,2,0,2">
                                        <TextBlock Text="临时" Foreground="#FCD34D" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2563EB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E293B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

            <!-- 右侧：搜索栏 + 遥测/遥控 Tab -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 搜索工具栏 -->
                <Border Grid.Row="0" Background="#13192D" Padding="8,5"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <WrapPanel Orientation="Horizontal">
                        <TextBlock Text="搜索：" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="SearchBox"
                                 Width="180" Style="{StaticResource DataTextBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="按中文名或变量名搜索，Enter / 按钮向下查找"
                                 Margin="0,0,6,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchNextCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="▼ 查找下一个" Command="{Binding SearchNextCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"/>
                        <Separator Width="1" Background="{StaticResource BorderBrush}"
                                   VerticalAlignment="Stretch" Margin="0,2,12,2"/>
                        <Button Content="▼ 定位未通过" Command="{Binding NextUnverifiedCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="循环定位当前标签页中未通过验证（绿点）的行"/>
                    </WrapPanel>
                </Border>

                <!-- 遥测 / 遥控 Tab -->
                <TabControl Grid.Row="1"
                        SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0">

                <!-- DataGrid 公共列头 & 单元格样式 -->
                <TabControl.Resources>
                    <!-- 覆盖系统画刷：防止 DataGrid 失焦后选中行/列变白 -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                     Color="#1E3A5F"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                     Color="#172033"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                     Color="#E2E8F0"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                     Color="#94A3B8"/>

                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="Padding"    Value="8,4"/>
                        <Setter Property="FontSize"   Value="12"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="8,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E3A5F"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <!-- ── 遥测 Tab ──────────────────────────────────────────── -->
                <TabItem Header="📊 遥测（只读）">
                    <DataGrid x:Name="TelGrid"
                              ItemsSource="{Binding TelemeterRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              ClipboardCopyMode="IncludeHeader"
                              SelectionUnit="CellOrRowHeader"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="{StaticResource BackgroundBrush}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0D1526"
                              BorderThickness="0"
                              RowHeight="28"
                              FontFamily="Consolas"
                              FontSize="12">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="22" Header="" IsReadOnly="True">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background"   Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Focusable"    Value="False"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="16" Height="16" Padding="0"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.ToggleVerifyRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="点击手动切换；立即比对通过后自动变绿">
                                            <Ellipse Width="10" Height="10"
                                                     Fill="{Binding IsVerified,
                                                            Converter={StaticResource BoolToColor},
                                                            ConverterParameter='#22C55E|#475569'}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="中文名"     Binding="{Binding ChineseName,  Mode=TwoWay}" Width="150"/>
                            <DataGridTextColumn Header="变量名"     Binding="{Binding VariableName, Mode=TwoWay}" Width="120"/>
                            <DataGridTextColumn Header="地址"       Binding="{Binding StartAddress}" Width="55"         IsReadOnly="True"/>
                            <DataGridTextColumn Header="数量"       Binding="{Binding Quantity}"     Width="40"         IsReadOnly="True"/>
                            <DataGridTextColumn Header="原始寄存器" Binding="{Binding RawDisplay}"   Width="Auto" MinWidth="80" IsReadOnly="True"/>
                            <!-- 读取值：右键可切换 uint / int / 字符串 三种解析模式 -->
                            <DataGridTemplateColumn Header="读取值" Width="100" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PhysicalValue}"
                                                   Padding="8,2" VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="15"
                                                   Foreground="#60A5FA"
                                                   ToolTip="{Binding DisplayModeLabel}">
                                            <TextBlock.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                         RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="🔢 uint（无符号整数）"
                                                              IsChecked="{Binding IsUIntMode, Mode=OneWay}"
                                                              Command="{Binding SetDisplayModeCommand}"
                                                              CommandParameter="uint"/>
                                                    <MenuItem Header="± int（有符号整数）"
                                                              IsChecked="{Binding IsIntMode, Mode=OneWay}"
                                                              Command="{Binding SetDisplayModeCommand}"
                                                              CommandParameter="int"/>
                                                    <MenuItem Header="🔤 字符串（ASCII）"
                                                              IsChecked="{Binding IsStringMode, Mode=OneWay}"
                                                              Command="{Binding SetDisplayModeCommand}"
                                                              CommandParameter="str"/>
                                                    <Separator/>
                                                    <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                                                </ContextMenu>
                                            </TextBlock.ContextMenu>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="单位"       Binding="{Binding Unit}"         Width="55"         IsReadOnly="True"/>
                            <DataGridTextColumn Header="取值范围"   Binding="{Binding ValueRange}"   Width="160"        IsReadOnly="True"/>
                            <DataGridTextColumn Header="比例系数"   Binding="{Binding ScaleFactor}"  Width="70"         IsReadOnly="True"/>
                            <DataGridTextColumn Header="更新时间"   Binding="{Binding LastUpdated}"  Width="*"          IsReadOnly="True"/>
                                                    <!-- 删除行按钮 -->
                            <DataGridTemplateColumn Width="30" Header="" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×"
                                                Width="20" Height="18"
                                                Padding="0" FontSize="12"
                                                Foreground="#EF4444" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand"
                                                ToolTip="删除此行"
                                                Command="{Binding DataContext.DeleteRegisterRowCommand,
                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
</DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ── 遥控 Tab ──────────────────────────────────────────── -->
                <TabItem Header="🎛 遥控（可写）">
                    <DataGrid x:Name="CtrlGrid"
                              ItemsSource="{Binding ControlRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              ClipboardCopyMode="IncludeHeader"
                              SelectionUnit="CellOrRowHeader"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="{StaticResource BackgroundBrush}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0D1526"
                              BorderThickness="0"
                              RowHeight="32"
                              FontFamily="Consolas"
                              FontSize="12">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="22" Header="" IsReadOnly="True">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background"   Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Focusable"    Value="False"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="16" Height="16" Padding="0"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.ToggleVerifyRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="点击手动切换；立即比对通过后自动变绿">
                                            <Ellipse Width="10" Height="10"
                                                     Fill="{Binding IsVerified,
                                                            Converter={StaticResource BoolToColor},
                                                            ConverterParameter='#22C55E|#475569'}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="中文名"   Binding="{Binding ChineseName,  Mode=TwoWay}" Width="150"/>
                            <DataGridTextColumn Header="变量名"   Binding="{Binding VariableName, Mode=TwoWay}" Width="120"/>
                            <DataGridTextColumn Header="地址"     Binding="{Binding StartAddress}" Width="55"        IsReadOnly="True"/>
                            <DataGridTextColumn Header="数量"     Binding="{Binding Quantity}"     Width="40"        IsReadOnly="True"/>
                            <DataGridTextColumn Header="原始寄存器" Binding="{Binding RawDisplay}" Width="Auto" MinWidth="80" IsReadOnly="True"/>
                            <!-- 当前值：常驻 TextBox，失焦后自动触发 FC16 写入 -->
                            <DataGridTemplateColumn Header="当前值（编辑后失焦写入）" Width="160" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding WriteValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" Foreground="#E2E8F0"
                                                 BorderBrush="Transparent" BorderThickness="0"
                                                 Padding="6,2" FontFamily="Consolas" FontSize="12"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="{Binding RawDisplay}"
                                                 GotFocus="CtrlWriteCell_GotFocus"
                                                 LostFocus="CtrlWriteCell_LostFocus"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="单位"     Binding="{Binding Unit}"         Width="55"        IsReadOnly="True"/>
                            <DataGridTextColumn Header="取值范围" Binding="{Binding ValueRange}"   Width="150"       IsReadOnly="True"/>
                            <DataGridTextColumn Header="比例系数" Binding="{Binding ScaleFactor}"  Width="70"        IsReadOnly="True"/>

                            <DataGridTextColumn Header="更新时间" Binding="{Binding LastUpdated}" Width="*"/>
                                                    <!-- 删除行按钮 -->
                            <DataGridTemplateColumn Width="30" Header="" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×"
                                                Width="20" Height="18"
                                                Padding="0" FontSize="12"
                                                Foreground="#EF4444" Background="Transparent"
                                                BorderThickness="0" Cursor="Hand"
                                                ToolTip="删除此行"
                                                Command="{Binding DataContext.DeleteRegisterRowCommand,
                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
</DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                </TabControl>
            </Grid><!-- /右侧包装 Grid -->
        </Grid>

        <!-- ===== 底部：日志 ===== -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,4" Background="#13192D"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="主站日志"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="清空" Width="50" Height="22"
                                Command="{Binding ClearLogUiCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="4,0"/>
                    </DockPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}"
                                           FontFamily="Consolas, Courier New"
                                           FontSize="11" Padding="12,1">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="Warn">
                                                    <Setter Property="Foreground" Value="#F97316"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
